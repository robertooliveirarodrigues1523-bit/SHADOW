HPDisplay.Font = Enum.Font.GothamBold
HPDisplay.TextSize = 18
HPDisplay.ZIndex = 5

local currentTween = nil
local currentNumberThread = nil

local function updateUI(humanoid)
    local health = humanoid.Health
    local maxHealth = humanoid.MaxHealth
    local percent = math.clamp(health / maxHealth, 0, 1)
    
    local targetColor
    if health <= 0 then
        targetColor = Color3.fromRGB(200, 40, 40)
    elseif percent <= 0.1 then
        targetColor = Color3.fromRGB(200, 40, 40)
    elseif percent <= 0.5 then
        targetColor = Color3.fromRGB(220, 180, 0)
    elseif health >= maxHealth then
        targetColor = Color3.fromRGB(30, 180, 30)
    else
        targetColor = Color3.fromRGB(60, 60, 60)
    end

    if currentTween then currentTween:Cancel() end
    if currentNumberThread then task.cancel(currentNumberThread) end

    if health <= 0 then FillBar.BackgroundColor3 = targetColor end

    currentTween = TweenService:Create(FillBar, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Size = UDim2.new(percent, 0, 1, 0),
        BackgroundColor3 = targetColor
    })
    currentTween:Play()

    currentNumberThread = task.spawn(function()
        local startValue = tonumber(HPDisplay.Text:match("%d+")) or 0
        local endValue = math.floor(health)
        local startTick = tick()
        
        while tick() - startTick < 0.5 do
            local elapsed = tick() - startTick
            local progress = elapsed / 0.5
            local lerpedValue = math.floor(startValue + (endValue - startValue) * progress)
            HPDisplay.Text = math.max(0, lerpedValue) .. "%"
            task.wait()
        end
        HPDisplay.Text = math.max(0, endValue) .. "%"
    end)
end

local function setup(char)
    local humanoid = char:WaitForChild("Humanoid")
    FillBar.Size = UDim2.new(0, 0, 1, 0)
    HPDisplay.Text = "0%"
    humanoid.HealthChanged:Connect(function() updateUI(humanoid) end)
    humanoid.Died:Connect(function() updateUI(humanoid) end)
    updateUI(humanoid)
end

player.CharacterAdded:Connect(setup)
if player.Character then setup(player.Character) end
