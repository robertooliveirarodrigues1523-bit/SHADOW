-- 5. ANIMAÇÕES TWEEN
local function playTween(state)
    local targetSize, targetPos
    if state == "open" then
        targetSize = UDim2.new(0, 250, 0, 350); targetPos = UDim2.new(0, 20, 0.5, -175); MainFrame.Visible = true; isMinimized = false; AddBtn.Visible = true
    elseif state == "minimize" then
        targetSize = UDim2.new(0, 250, 0, 45); targetPos = MainFrame.Position; isMinimized = true; AddBtn.Visible = false
    elseif state == "close" then
        targetSize = UDim2.new(0, 250, 0, 0); targetPos = UDim2.new(0, 20, 0.5, 0); isMinimized = false; AddBtn.Visible = false
    end
    local tween = TweenService:Create(MainFrame, TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Size = targetSize, Position = targetPos})
    tween:Play()
    tween.Completed:Connect(function() if state == "close" then MainFrame.Visible = false end end)
end

-- 6. RENDERIZAÇÃO ESPECÍFICA (FOCO NA EXCLUSÃO INDIVIDUAL)
local function renderWaypoints()
    for _, v in pairs(Scroll:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
    local sortedIds = {}
    for id, _ in pairs(allWaypoints) do table.insert(sortedIds, id) end
    table.sort(sortedIds, function(a, b) if a == currentGameId then return true end if b == currentGameId then return false end return a < b end)
    
    for _, id in ipairs(sortedIds) do
        -- Variáveis locais para cada barra individualmente
        local data = allWaypoints[id]
        local isThisGame = (id == currentGameId)
        
        local Bar = Instance.new("Frame")
        Bar.Size = UDim2.new(0, 230, 0, 90); Bar.BackgroundColor3 = isThisGame and Color3.fromRGB(20, 20, 20) or Color3.fromRGB(35, 35, 35)
        Bar.Parent = Scroll; Instance.new("UICorner", Bar).CornerRadius = UDim.new(0, 8)
        
        local T1 = Instance.new("TextLabel")
        T1.Size = UDim2.new(0.6, 0, 0, 25); T1.Position = UDim2.new(0, 10, 0, 10); T1.Text = data.Title; T1.TextColor3 = Color3.fromRGB(255, 255, 255); T1.Font = Enum.Font.FredokaOne; T1.TextSize = 18; T1.TextXAlignment = Enum.TextXAlignment.Left; T1.BackgroundTransparency = 1; T1.Parent = Bar
        
        local T2 = Instance.new("TextLabel")
        T2.Size = UDim2.new(0.6, 0, 0, 20); T2.Position = UDim2.new(0, 10, 0, 38); T2.Text = data.GameName or "Unknown"; T2.TextColor3 = Color3.fromRGB(180, 180, 180); T2.Font = Enum.Font.SourceSansItalic; T2.TextSize = 15; T2.TextXAlignment = Enum.TextXAlignment.Left; T2.BackgroundTransparency = 1; T2.Parent = Bar
        
        local DEL = Instance.new("TextButton")
        DEL.Text = "DEL"; DEL.Size = UDim2.new(0, 35, 0, 25); DEL.Position = UDim2.new(1, -40, 0.1, 0); DEL.BackgroundColor3 = Color3.fromRGB(200, 0, 0); DEL.Parent = Bar

        -- EVENTO DE CLICK UNICO PARA ESTA BARRA ESPECIFICA
        DEL.MouseButton1Click:Connect(function()
            MainFrame.Visible = false; AddBtn.Visible = false
            DeleteAviso.Text = "⚠️ NOTIFICAÇÃO DE EXCLUSÃO\n\nDETALHES: Você solicitou a remoção de um registro específico.\n\nTÍTULO: ["..data.Title.."]\nJOGO: ["..(data.GameName or "Desconhecido").."]\n\nEsta ação irá remover apenas este waypoint de forma definitiva. Prosseguir?"
            DeleteFrame.Visible = true
            
            -- Limpar conexões antigas do botão OK global para não deletar itens errados
            local okConnection; okConnection = OkDel.MouseButton1Click:Connect(function()
                allWaypoints[id] = nil -- Deleta apenas o ID que capturamos neste loop
                saveData(allWaypoints)
                renderWaypoints()
                DeleteFrame.Visible = false; MainFrame.Visible = true; AddBtn.Visible = true
                okConnection:Disconnect() -- Desconecta para o próximo click ser independente
            end)
            
            -- Botão Cancelar também precisa limpar a conexão temporária
            local cancelConnection; cancelConnection = CancelDel.MouseButton1Click:Connect(function()
                DeleteFrame.Visible = false; MainFrame.Visible = true; AddBtn.Visible = true
                okConnection:Disconnect() -- Mata a ordem de deletar se cancelar
                cancelConnection:Disconnect()
            end)
        end)

        if isThisGame then
            local TP = Instance.new("TextButton")
            TP.Text = "TP"; TP.Size = UDim2.new(0, 35, 0, 25); TP.Position = UDim2.new(1, -80, 0.1, 0); TP.BackgroundColor3 = Color3.fromRGB(0, 180, 0); TP.Parent = Bar
            TP.MouseButton1Click:Connect(function() player.Character.HumanoidRootPart.CFrame = CFrame.new(data.Pos.x, data.Pos.y, data.Pos.z) end)
        else
            local COPY = Instance.new("TextButton")
            COPY.Text = "COPIAR"; COPY.Size = UDim2.new(0, 60, 0, 25); COPY.Position = UDim2.new(1, -110, 0.1, 0); COPY.BackgroundColor3 = Color3.fromRGB(0, 120, 215); COPY.Parent = Bar
            COPY.MouseButton1Click:Connect(function() if setclipboard then setclipboard(tostring(data.GameName)) end end)
        end
    end
end

