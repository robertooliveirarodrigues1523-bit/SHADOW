    if lobbyPosition and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        player.Character.HumanoidRootPart.CFrame = lobbyPosition
    end
end)

-- ANIMAÇÃO DE COR ÚNICA ARCO-ÍRIS E VELOCIDADE
RunService.RenderStepped:Connect(function()
    local hue = tick() % 4 / 4 -- Ciclo de 4 segundos
    local color = Color3.fromHSV(hue, 1, 1)
    
    strokeLobby.Color = color
    strokeOpen.Color = color
    strokeFrame.Color = color
    
    if player.Character and player.Character:FindFirstChild("Humanoid") then
        player.Character.Humanoid.WalkSpeed = targetSpeed
    end
end)
