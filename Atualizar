-- SISTEMA DE ANTI-MULTIPLICAÇÃO
if _G.LobbySystemLoaded then return else _G.LobbySystemLoaded = true end

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local HttpService = game:GetService("HttpService")
local player = Players.LocalPlayer
local targetSpeed = 40 
local gameId = tostring(game.PlaceId)
local fileName = "LobbyData_" .. gameId .. ".txt"

-- SISTEMA DE SALVAMENTO PERMANENTE
local function savePos(cf)
    local data = {pos = {cf.X, cf.Y, cf.Z}, rot = {cf:ToEulerAnglesXYZ()}}
    writefile(fileName, HttpService:JSONEncode(data))
end

local function loadPos()
    if isfile(fileName) then
        local success, data = pcall(function() return HttpService:JSONDecode(readfile(fileName)) end)
        if success then return CFrame.new(unpack(data.pos)) * CFrame.fromEulerAnglesXYZ(unpack(data.rot)) end
    end
    return nil
end

local lobbyPosition = loadPos()

-- INTERFACE
local screenGui = Instance.new("ScreenGui")
