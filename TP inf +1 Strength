-- VERIFICAÇÃO DE ID DO JOGO (PLACE ID)
if game.PlaceId ~= 105241313130846 then return end

-- SISTEMA ANTI-MULTIPLICAÇÃO
if _G.ScriptIlhaExecutado then return else _G.ScriptIlhaExecutado = true end

-- 1. CONFIGURAÇÕES
local Player = game.Players.LocalPlayer
local Lighting = game:GetService("Lighting")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local Rand = Random.new()

local TAMANHO_ILHA = 1000
local POSICAO_ILHA = Vector3.new(0, 15000, 0)
local TOTAL_ARVORES = 535
local TOTAL_PEDRAS_ILHA = 150
local COD_FOGUEIRA, COD_VAGALUMES, COD_ILHA, COD_TEMPO = "001", "002", "003", "004"

local tempoAtivado, ilha, estado = false, nil, "normal"

-- Interface Fade
local ScreenGui = Instance.new("ScreenGui", Player.PlayerGui)
ScreenGui.IgnoreGuiInset = true
local BlackFrame = Instance.new("Frame", ScreenGui)
BlackFrame.Size, BlackFrame.BackgroundColor3, BlackFrame.BackgroundTransparency = UDim2.new(1, 0, 1, 0), Color3.new(0, 0, 0), 1

-- 2. FUNÇÃO INVISIBILIDADE
local function setInvisibilidade(char, bool)
    for _, v in pairs(char:GetDescendants()) do
        if v:IsA("BasePart") or v:IsA("Decal") then
            v.Transparency = bool and 1 or (v.Name == "HumanoidRootPart" and 1 or 0)
        end
    end
end

-- 3. CRIAÇÃO DE PEDRA ANGULAR (FORMATO DA IMAGEM)
local function criarPedraAngular(pos, escalaBase, cor)
    local modeloPedra = Instance.new("Model", workspace)
    local numPartes = Rand:NextInteger(3, 5)
    local forma = Enum.PartType.Block
    
    for i = 1, numPartes do
        local p = Instance.new("Part", modeloPedra)
        local tam = (escalaBase or Vector3.new(4, 3, 4)) * Rand:NextNumber(0.8, 1.2)
        p.Size = tam
        p.Shape = forma
        p.Position = pos + Vector3.new(Rand:NextNumber(-1,1), Rand:NextNumber(-0.5, 0.5), Rand:NextNumber(-1,1))
        p.CFrame = p.CFrame * CFrame.Angles(math.rad(Rand:NextNumber(0,360)), math.rad(Rand:NextNumber(0,360)), math.rad(Rand:NextNumber(0,360)))
        p.Anchored, p.Material, p.Color = true, Enum.Material.Slate, cor or Color3.fromRGB(80, 80, 80)
    end
end

-- 4. FOGUEIRA COM CÍRCULO DE PEDRAS ANGULARES
local function criarFogueiraRealista(codigo)
    if not ilha or codigo ~= COD_FOGUEIRA then return end
    local fogModel = Instance.new("Model", workspace)
    
    local numPedras = 14
    local raioFogueira = 6
    for i = 1, numPedras do
        local angulo = (i / numPedras) * math.pi * 2
        local x = math.cos(angulo) * raioFogueira
        local z = math.sin(angulo) * raioFogueira
        criarPedraAngular(POSICAO_ILHA + Vector3.new(x, -0.5, z), Vector3.new(2, 1.5, 2), Color3.fromRGB(90, 90, 90))
    end

    for i = 1, 6 do 
        local log = Instance.new("Part", fogModel)
        log.Size = Vector3.new(1, 1, 6)
        log.CFrame = CFrame.new(POSICAO_ILHA + Vector3.new(0, 1.2, 0)) * CFrame.Angles(0, math.rad(i*60), math.rad(35))
        log.Anchored, log.Material, log.Color = true, Enum.Material.Wood, Color3.fromRGB(60, 40, 25)
    end
    
    local ef = Instance.new("Part", fogModel)
    ef.Size, ef.Position, ef.Transparency, ef.Anchored = Vector3.new(1,1,1), POSICAO_ILHA + Vector3.new(0, 2, 0), 1, true
    Instance.new("Fire", ef).Size = 14
    _G.somFogo = Instance.new("Sound", ef); _G.somFogo.SoundId = "rbxassetid://144521469"; _G.somFogo.Looped, _G.somFogo.Volume = true, 1
end

-- 5. ÁRVORES (MANTIDAS)
local function criarArvore(pos)
    local m = Instance.new("Model", workspace)
    local t = Instance.new("Part", m)
    t.Shape, t.Size = Enum.PartType.Cylinder, Vector3.new(25, 4, 4)
    t.CFrame = CFrame.new(pos + Vector3.new(0, 12, 0)) * CFrame.Angles(0, 0, math.rad(90))
    t.Anchored, t.Material, t.Color = true, Enum.Material.Wood, Color3.fromRGB(80, 55, 40)
    for i = 1, 7 do
        local f = Instance.new("Part", m)
        f.Shape, f.Size = Enum.PartType.Ball, Vector3.new(14, 11, 14)
        f.Position = pos + Vector3.new(Rand:NextNumber(-6,6), 18 + i*2, Rand:NextNumber(-6,6))
        f.Anchored, f.Material, f.Color = true, Enum.Material.Grass, Color3.fromRGB(34, 78, 34)
    end
end

-- 6. SETUP GERAL
task.spawn(function()
    if COD_TEMPO == "004" then tempoAtivado = true end
    if COD_ILHA == "003" then
        ilha = Instance.new("Part", workspace)
        ilha.Name, ilha.Size, ilha.Position, ilha.Anchored = "IlhaSecreta", Vector3.new(TAMANHO_ILHA, 2, TAMANHO_ILHA), POSICAO_ILHA, true
        ilha.Material, ilha.Color = Enum.Material.Grass, Color3.fromRGB(40, 80, 40)
        
        for i = 1, 4 do -- Paredes (Agora visíveis e sólidas)
            local p = Instance.new("Part", workspace)
            p.Size = (i<3) and Vector3.new(10, 60, 1000) or Vector3.new(1000, 60, 10)
            p.Position = POSICAO_ILHA + ((i==1 and Vector3.new(500,30,0)) or (i==2 and Vector3.new(-500,30,0)) or (i==3 and Vector3.new(0,30,500)) or Vector3.new(0,30,-500))
            p.Anchored, p.Transparency, p.Material, p.Color = true, 0.0, Enum.Material.Concrete, Color3.fromRGB(50, 50, 50)
        end

        criarFogueiraRealista("001")
        for i = 1, TOTAL_PEDRAS_ILHA do
            local x, z = Rand:NextNumber(-480, 480), Rand:NextNumber(-480, 480)
            if Vector2.new(x, z).Magnitude > 80 then 
                criarPedraAngular(POSICAO_ILHA + Vector3.new(x, 0, z), Vector3.new(Rand:NextNumber(3, 15), Rand:NextNumber(3, 15), Rand:NextNumber(3, 15)))
            end
        end

        for i = 1, TOTAL_ARVORES do
            local x, z = Rand:NextNumber(-480, 480), Rand:NextNumber(-480, 480)
            if Vector2.new(x, z).Magnitude > 80 then criarArvore(POSICAO_ILHA + Vector3.new(x, 0, z)) end
            if i % 60 == 0 then task.wait() end
        end
    end
end)

-- 7. LÓGICA DE TELEPORTE
RunService.RenderStepped:Connect(function()
    if tempoAtivado then Lighting.ClockTime, Lighting.Brightness = 14, 3 end
    local char = Player.Character; local root = char and char:FindFirstChild("HumanoidRootPart")
    local jBtn = Player.PlayerGui:FindFirstChild("JumpButton", true)
    if jBtn and root and ilha then
        if not jBtn.Visible and estado == "normal" then
            estado = "ilha"; root.CFrame = CFrame.new(POSICAO_ILHA + Vector3.new(0, 8, 0))
            root.Anchored = true; setInvisibilidade(char, true)
            if _G.somFogo then _G.somFogo:Play() end
            BlackFrame.BackgroundTransparency = 0
            TweenService:Create(BlackFrame, TweenInfo.new(1), {BackgroundTransparency = 1}):Play()
        elseif jBtn.Visible and estado == "ilha" then
            estado = "normal"; root.Anchored = false; setInvisibilidade(char, false)
            if _G.somFogo then _G.somFogo:Stop() end
            BlackFrame.BackgroundTransparency = 0
            TweenService:Create(BlackFrame, TweenInfo.new(1), {BackgroundTransparency = 1}):Play()
        end
    end
end)
